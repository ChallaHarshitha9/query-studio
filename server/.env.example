DATABASE_URL=postgres://postgres:postgres@localhost:5432/query_studio
JWT_SECRET=change-this-to-a-long-random-string
PORT=4000

# Optional: enables the "Describe your query in English" feature via GitHub Models
# (https://github.com/marketplace/models). Leave blank to disable that feature only —
# everything else in the app works without it.
# Create a GitHub personal access token with "Models" read access and paste it here.
GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4o-mini
